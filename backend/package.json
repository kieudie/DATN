{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && yarn copy-resources",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "yarn copy-resources && env-cmd -f .env nest start",
    "start:dev": "env-cmd -f .env nest start --watch",
    "start:test": "yarn copy-resources && env-cmd -f .env nest start --watch",
    "start:debug": "yarn copy-resources && env-cmd -f .env nest start --debug --watch",
    "pretty": "prettier --write \"./**/*.{js,jsx,ts,tsx,json,yml}\"",
    "start:prod": "yarn copy-resources && env-cmd -f .env node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "copy-resources": "ts-node scripts/copy-resources.ts",
    "prebuild": "rimraf dist",
    "migration:generate": "yarn typeorm migration:create",
    "migration:up": "env-cmd -f .env yarn typeorm migration:run -d dist/src/typeorm/orm-seeding-migration.datasource.js",
    "migration:down": "env-cmd -f .env yarn typeorm migration:revert -d dist/src/typeorm/orm-seeding-migration.datasource.js",
    "seed:run": "env-cmd -f .env yarn typeorm-extension seed:run -d dist/src/typeorm/orm-seeding-migration.datasource.js"  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.22.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shelljs": "^0.10.0",
    "typeorm": "^0.3.28",
    "typeorm-extension": "^3.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/shelljs": "^0.10.0",
    "@types/supertest": "^7.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
